{
  "name": "slipcast",
  "private": true,
  "version": "0.1.0",
  "description": "Turn a solid model into printable geometry for plaster slip-casting molds. Runs entirely in the browser.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/engine",
    "packages/cli",
    "packages/app"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:engine": "npm run test --workspace @slipcast/engine",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev --workspace @slipcast/app",
    "cli": "npm run start --workspace @slipcast/cli --"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
