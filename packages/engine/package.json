{
  "name": "@slipcast/engine",
  "version": "0.1.0",
  "description": "Geometry engine that turns a solid model into printable slip-cast mold geometry. Pure TypeScript + WASM; runs identically in the browser and in Node.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "manifold-3d": "^3.0.1",
    "three": "^0.171.0",
    "three-mesh-bvh": "^0.8.3"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "fast-check": "^3.23.2"
  }
}
